Step 3 — Lambda Code (index.js)

import { S3Client, GetObjectCommand, PutObjectCommand, HeadObjectCommand } from "@aws-sdk/client-s3";
import sharp from "sharp";

const s3 = new S3Client({});

const BUCKET = process.env.BUCKET;

const SIZES = {
  w80: 80,
  w300: 300,
  w400: 400,
  w800: 800,
  w1200: 1200
};

export const handler = async (event) => {
  try {
    const path = event.rawPath || event.path;

    // Example: /derived/w400/articles/foo.jpg
    const match = path.match(/derived\/(w\d+)\/(.+)/);

    if (!match) {
      return { statusCode: 400, body: "Invalid path" };
    }

    const sizeKey = match[1];
    const imagePath = match[2];

    const width = SIZES[sizeKey];

    const originalKey = `library/${imagePath}`;

    // Fetch original
    const original = await s3.send(
      new GetObjectCommand({
        Bucket: BUCKET,
        Key: originalKey
      })
    );

    const buffer = await streamToBuffer(original.Body);

    // Generate missing sizes
    await Promise.all(
      Object.entries(SIZES).map(async ([key, w]) => {
        const derivedKey = `derived/${key}/${imagePath}`;

        try {
          // Check if exists
          await s3.send(
            new HeadObjectCommand({
              Bucket: BUCKET,
              Key: derivedKey
            })
          );
          return; // exists
        } catch {}

        const resized = await sharp(buffer)
          .resize({ width: w })
          .jpeg({ quality: 75 })
          .toBuffer();

        await s3.send(
          new PutObjectCommand({
            Bucket: BUCKET,
            Key: derivedKey,
            Body: resized,
            ContentType: "image/jpeg",
            CacheControl: "public, max-age=31536000, immutable"
          })
        );
      })
    );

    // Return requested image
    const finalKey = `derived/${sizeKey}/${imagePath}`;

    const final = await s3.send(
      new GetObjectCommand({
        Bucket: BUCKET,
        Key: finalKey
      })
    );

    const finalBuffer = await streamToBuffer(final.Body);

    return {
      statusCode: 200,
      headers: {
        "Content-Type": "image/jpeg",
        "Cache-Control": "public, max-age=31536000, immutable"
      },
      body: finalBuffer.toString("base64"),
      isBase64Encoded: true
    };
  } catch (err) {
    console.error(err);
    return { statusCode: 500, body: "Error processing image" };
  }
};

const streamToBuffer = async (stream) => {
  const chunks = [];
  for await (const chunk of stream) {
    chunks.push(chunk);
  }
  return Buffer.concat(chunks);
};


